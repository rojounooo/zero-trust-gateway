# Internal URL — used for server-to-server calls (token exchange, admin API)
KEYCLOAK_URL=http://10.0.0.1:8080

# Browser-facing URL — used to redirect the user to Keycloak login page
KEYCLOAK_BROWSER_URL=http://<gateway-ip>:8080

KEYCLOAK_REALM=hospital
KEYCLOAK_CLIENT_ID=fastapi-app
KEYCLOAK_CLIENT_SECRET=

# Must match the redirect URI set in Keycloak client settings
KEYCLOAK_REDIRECT_URI=http://<gateway-ip>:10000/callback

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Set to path of CA cert file in production. False disables verification.
KEYCLOAK_CA_CERT=False
